# API server configuration
API_PORT=8000
API_HOST=0.0.0.0

# Whisper server configuration
WHISPER_SERVER_HOST=localhost
WHISPER_SERVER_PORT=9000
# Alternative: WHISPER_SERVER_URL=http://localhost:9000  # overrides host/port

# Model configuration
