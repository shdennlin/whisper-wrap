# ===========================================================================
# whisper-wrap — environment configuration
#
# Three tiers — start at the top and stop when you have what you need:
#   1. REQUIRED-LIKE  — defaults are sane; touch only if you have a reason
#   2. OPTIONAL       — enables /ask (Gemini) and tunes the noise filter
#   3. ADVANCED       — backend/VAD/runtime knobs; almost nobody changes these
# ===========================================================================

# ============================ 1. REQUIRED-LIKE =============================
# Bind address + port. 0.0.0.0 lets other devices on your LAN/Tailnet reach
# the server (iPhone Shortcut, phone PWA). Use 127.0.0.1 for localhost-only.
API_PORT=8000
API_HOST=0.0.0.0

# Active model — must be a key in registry/models.yaml or pre-downloaded
# with `make download-model MODEL=<name>`. Default `breeze-asr-25` covers
# zh-TW + en well; switch to `large-v3-turbo` for broader language coverage.
MODEL_NAME=breeze-asr-25


# ================================ 2. OPTIONAL ==============================
# Gemini for POST /ask. Without GEMINI_API_KEY set, /ask returns 502.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_SYSTEM_PROMPT=                  # Override built-in Taiwan-friendly persona

# Transcription post-process filter (shared by /listen, /transcribe, /ask,
# /v1/audio/*). Whisper sometimes returns empty strings or pure punctuation
# ("。", "。。。") for noise; this filter suppresses those results so they
# don't pollute history or burn Gemini tokens. Disable temporarily for
# diagnostics if a real utterance is being dropped.
# FILTER_EMPTY_ENABLED=true
# FILTER_MIN_DURATION_MS=500             # Lower to ~300 for short CJK words

# Meeting Mode (POST /transcribe/meeting). Long-form diarization via WhisperX
# + pyannote.audio. Opt-in: requires the [meeting] extras (~1.5 GB):
#     uv sync --extra meeting
# pyannote needs a Hugging Face account with user-agreements accepted on
# ALL THREE gated repos (the third is a transitive PLDA backend loaded by
# speaker-diarization-3.1 at construction time — easy to miss):
#     https://huggingface.co/pyannote/speaker-diarization-3.1
#     https://huggingface.co/pyannote/segmentation-3.0
#     https://huggingface.co/pyannote/speaker-diarization-community-1
# Without HF_TOKEN (or the [meeting] extras) the endpoint returns HTTP 503;
# every other endpoint keeps working.
HF_TOKEN=
# MEETING_MODEL_NAME=                    # Defaults to MODEL_NAME; set to point meeting analysis at a different registry model
# MEETING_JOB_TTL_SECONDS=3600           # Seconds before completed job results are evicted from memory
# MEETING_MAX_JOBS=20                    # Maximum job results kept in memory; oldest is evicted first
# MEETING_DIARIZATION_PIPELINE=pyannote/speaker-diarization-3.1
# MEETING_ALIGN_MODEL=                   # wav2vec2 model id; unset = WhisperX per-language default


# ================================ 3. ADVANCED ==============================
# Off-registry model: bypass MODEL_NAME and point at a CT2 model directory.
# MODEL_DIR=/absolute/path/to/ct2-model-dir

# VAD backend selection (WS /listen).
#   unset (default): silero if installed, otherwise rms (one INFO log line).
#   "silero": neural VAD via silero-vad (~1 MB TorchScript, cached after
#             first start). Robust against fan noise + quiet speech.
#   "rms":    cheap energy threshold. Tune SILENCE_RMS_THRESHOLD in code.
# VAD_BACKEND=

# Whisper backend selection.
#   unset (default): macOS → ggml (pywhispercpp + Core ML/ANE);
#                    Linux → ct2 (faster-whisper).
#   "ct2":  force CTranslate2 (works everywhere).
#   "ggml": force pywhispercpp (macOS only; Linux startup fails).
# First run with ggml triggers ~10-30s Core ML encoder compile (lifespan
# blocks startup; INFO logs per-second). Subsequent starts are fast.
# BACKEND_FORMAT=

# CTranslate2 runtime hints (apply only when active variant is ct2).
#   COMPUTE_TYPE: "default" auto-picks. Apple Silicon CPU MUST stay "default"
#                 (int8_float16 raises ValueError). CUDA can use "int8_float16".
#   DEVICE: "auto" picks CUDA if available, else CPU.
COMPUTE_TYPE=default
DEVICE=auto

# File handling.
MAX_FILE_SIZE_MB=100
TEMP_DIR=/tmp/whisper-wrap
LOG_LEVEL=DEBUG
UPLOAD_TIMEOUT_SECONDS=30

# HTTPS for `make dev-https` (typically Tailscale-issued cert + key).
# IMPORTANT: this file is parsed by Make's `include`, NOT sourced by a shell.
# Do NOT wrap values in quotes and do NOT prefix with `export` — Make keeps
# the quotes verbatim and the cert-path existence check then fails on a
# filename that includes literal " characters.
# WHISPER_CERT=/abs/path/to/<host>.<tailnet>.ts.net.crt
# WHISPER_KEY=/abs/path/to/<host>.<tailnet>.ts.net.key
