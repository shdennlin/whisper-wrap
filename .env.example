# API server configuration
API_PORT=8000
API_HOST=0.0.0.0

# Whisper server configuration
WHISPER_SERVER_HOST=localhost
WHISPER_SERVER_PORT=9000
# Alternative: WHISPER_SERVER_URL=http://localhost:9000  # overrides host/port

# Model configuration
MODEL_NAME=large-v3-turbo-q8
MODEL_PATH=./models/ggml-large-v3-turbo-q8_0.bin

# File handling configuration
MAX_FILE_SIZE_MB=100
TEMP_DIR=/tmp/whisper-wrap
LOG_LEVEL=DEBUG
UPLOAD_TIMEOUT_SECONDS=30

# Whisper-server process management (all optional, defaults shown)
# WHISPER_AUTO_RESTART=true                                        # Auto-restart whisper-server on failure and retry
# WHISPER_BINARY_PATH=./whisper.cpp/build/bin/whisper-server       # Path to whisper-server binary
# WHISPER_MAX_RETRIES=2                                            # Number of retry attempts after restart
