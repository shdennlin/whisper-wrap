# API server configuration
API_PORT=8000
API_HOST=0.0.0.0

# Model configuration
#
# MODEL_NAME resolves to an entry in registry/models.yaml.
# MODEL_DIR overrides MODEL_NAME and points at a CT2 model directory directly
# (handy for off-registry checkouts).
MODEL_NAME=breeze-asr-25
# MODEL_DIR=/absolute/path/to/ct2-model-dir

# VAD backend selection (v2.2).
#   VAD_BACKEND picks the voice-activity detector used by WS /listen.
#     - unset (default): try silero (neural, ~1 MB model) first; fall back to
#       rms with one INFO log line if silero-vad is not installed.
#     - "silero": neural VAD via silero-vad. Fixes RMS failure modes (fan noise
#       false-positive, quiet speech false-negative). Recommended.
#     - "rms": cheap int16 RMS-energy threshold (v2.1 fallback). Tunable via
#       SILENCE_RMS_THRESHOLD in app/services/vad.py if you stay on this path.
#   First start with silero downloads ~1 MB TorchScript model to
#   ~/.cache/torch/hub/snakers4_silero-vad/ (one-time, requires internet).
# VAD_BACKEND=

# Backend selection (v2.1).
#   BACKEND_FORMAT picks which variant of the active model the lifespan loads:
#     - unset (default): platform-resolved — macOS picks the `ggml` variant
#       (pywhispercpp + Core ML/ANE); Linux picks the `ct2` variant (faster-whisper).
#     - "ct2": force CTranslate2/faster-whisper backend (Linux default, macOS fallback).
#     - "ggml": force pywhispercpp + Core ML backend (macOS only; Linux startup fails).
#   First run on macOS with `ggml` triggers a one-time Core ML encoder compile
#   (~10-30 s); the lifespan blocks until the compile finishes and logs per-second
#   progress lines. Subsequent starts on the same host reuse the cached `.mlmodelc`.
# BACKEND_FORMAT=

# CTranslate2 runtime hints (applies when the active variant is `ct2`).
#   COMPUTE_TYPE: "default" lets CT2 auto-pick the best path for the device.
#     - Apple Silicon CPU: must use "default" (int8_float16 raises ValueError).
#     - CUDA GPU: "int8_float16" or "float16" work directly.
#   DEVICE: "auto" picks CUDA if available, otherwise CPU.
COMPUTE_TYPE=default
DEVICE=auto

# Gemini configuration for POST /ask.
#   GEMINI_API_KEY: required for /ask. If unset, /ask returns 502.
#   GEMINI_MODEL: free-tier default works for general Q&A; override for other models.
#   GEMINI_SYSTEM_PROMPT: optional. If unset, a baked-in Taiwan-friendly persona is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_SYSTEM_PROMPT=

# File handling configuration
MAX_FILE_SIZE_MB=100
TEMP_DIR=/tmp/whisper-wrap
LOG_LEVEL=DEBUG
UPLOAD_TIMEOUT_SECONDS=30
