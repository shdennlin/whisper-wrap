# ===========================================================================
# whisper-wrap — environment configuration (v3 Rust engine)
#
# Every variable below is read by the engine's config loader
# (engine/core/src/config.rs). Defaults are sane — set only what you need.
# The engine runs fine with no .env at all; this file documents the knobs.
# ===========================================================================

# -------------------------------- Server -----------------------------------
# Bind address + port. 0.0.0.0 lets other devices on your LAN/Tailnet reach
# the server (phone PWA, Shortcuts). Use 127.0.0.1 for localhost-only.
API_PORT=8000
API_HOST=0.0.0.0
# Optional bearer token required on every request when set (unset = open).
# ENGINE_TOKEN=

# -------------------------------- Model ------------------------------------
# Active model — must be a key in registry/models.yaml. Default breeze-asr-25
# covers zh-TW + en well; switch to large-v3-turbo for broader coverage.
MODEL_NAME=breeze-asr-25
# Off-registry: point straight at a model directory, bypassing MODEL_NAME.
# MODEL_DIR=/absolute/path/to/model-dir
# MODELS_DIR=models                     # where downloaded weights live
# REGISTRY_PATH=registry/models.yaml
# ACTIONS_PATH=registry/actions.yaml

# ------------------------------ LLM / /ask ---------------------------------
# Gemini for POST /ask. Without GEMINI_API_KEY set, /ask returns 502.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_SYSTEM_PROMPT=                 # override the built-in persona
# Generic OpenAI-compatible LLM provider (alternative to Gemini):
# LLM_PROVIDER=
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# ---------------------------- Capture / VAD --------------------------------
# Voice-activity detection backend for WS /listen (unset = auto).
# VAD_BACKEND=
# SILERO_VAD_MODEL=                     # path override for the silero VAD weights

# ------------------------------ Filtering ----------------------------------
# Suppress empty / punctuation-only transcripts (noise). Disable for diagnostics.
# FILTER_EMPTY_ENABLED=true
# FILTER_MIN_DURATION_MS=500            # lower to ~300 for short CJK words

# --------------------------- Files / storage -------------------------------
# MAX_FILE_SIZE_MB=100
# TEMP_DIR=/tmp/whisper-wrap
# UPLOAD_TIMEOUT_SECONDS=30
# DATA_DIR=data
